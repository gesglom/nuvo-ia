# Proveedor por defecto del runtime (localdev permite pruebas sin API externa)
NUVO_LLM_PROVIDER=localdev

# Lista de fallback separados por coma (ej: openai_compatible,ollama)
NUVO_LLM_FALLBACKS=
NUVO_LLM_TIMEOUT=120

# Ollama (open source local)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5-coder:7b

# OpenAI comercial
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Cualquier proveedor OpenAI-compatible (Groq, Together, LM Studio, vLLM, etc.)
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=

# Anthropic comercial
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Memory provider: local|engram
NUVO_MEMORY_PROVIDER=local
ENGRAM_API_URL=
ENGRAM_API_KEY=
ENGRAM_TIMEOUT=20
